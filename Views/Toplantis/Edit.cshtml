@model DernekSitesi.Models.Toplanti
@{
    ViewData["Title"] = "Toplantı Düzenle";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header text-dark p-4 border-0" style="background: linear-gradient(135deg, #fdcb6e 0%, #ffeaa7 100%);">
                    <h3 class="mb-0 fw-bold"><i class="fa-solid fa-calendar-pen me-2"></i>Toplantı Düzenle</h3>
                </div>
                <div class="card-body p-5">
                    <form asp-action="Edit">
                        <input type="hidden" asp-for="Id" />

                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted small">TOPLANTI BAŞLIĞI</label>
                            <input asp-for="Baslik" class="form-control form-control-lg bg-light border-0 shadow-sm" />
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-muted small">TARİH VE SAAT</label>
                                <input asp-for="Tarih" class="form-control form-control-lg bg-light border-0 shadow-sm" />
                            </div>
                            <div class="col-md-6 mt-4 mt-md-0">
                                <label class="form-label fw-bold text-muted small">KONUM / ADRES</label>
                                <input asp-for="Konum" class="form-control form-control-lg bg-light border-0 shadow-sm" />
                            </div>
                        </div>

                        <div class="mb-5 p-3 bg-light rounded-3 border" style="border-color: #e9ecef !important;">
                            <div class="form-check form-switch form-check-lg d-flex align-items-center mb-0">
                                <input class="form-check-input me-3" type="checkbox" asp-for="GelecekToplantiMi" style="transform: scale(1.5);">
                                <label class="form-check-label fw-bold text-dark" style="margin-top: 2px;">Bu Yaklaşan Bir Toplantı Mı?</label>
                            </div>
                            <small class="text-muted ms-5 d-block mt-1">İşaretli olan toplantı Ana Sayfada "Yaklaşan Toplantı" vitrininde gösterilir.</small>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-2">
                            <a asp-action="Index" class="btn btn-light fw-bold px-4 py-2 rounded-pill">İptal Et</a>
                            <button type="submit" class="btn btn-warning fw-bold px-5 py-2 rounded-pill shadow-sm text-dark">
                                <i class="fa-solid fa-check me-2"></i>Değişiklikleri Kaydet
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>