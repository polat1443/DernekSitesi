@model IEnumerable<DernekSitesi.Models.Toplanti>
@{
    ViewData["Title"] = "Toplantı Listesi";
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 p-4 bg-white rounded-4 shadow-sm border" style="border-color: #f1f2f6 !important;">
        <div class="d-flex align-items-center">
            <div class="p-3 rounded-circle me-3" style="background: rgba(253, 203, 110, 0.15); color: #e1b12c;">
                <i class="fa-solid fa-calendar-days fa-2x"></i>
            </div>
            <div>
                <h2 class="fw-bold mb-0 text-dark">Toplantı Yönetimi</h2>
                <p class="text-muted mb-0">Dernek toplantılarını ve etkinliklerini buradan planlayabilirsiniz.</p>
            </div>
        </div>
        <a asp-action="Create" class="btn btn-warning text-dark fw-bold px-4 py-2 rounded-pill shadow-sm">
            <i class="fa-solid fa-plus me-2"></i>Yeni Toplantı Planla
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="text-white" style="background-color: #2d3436;">
                    <tr>
                        <th class="py-3 ps-4">TOPLANTI BAŞLIĞI</th>
                        <th>TARİH VE SAAT</th>
                        <th>KONUM</th>
                        <th>DURUM</th>
                        <th class="text-end pe-4">İŞLEMLER</th>
                    </tr>
                </thead>
                <tbody class="bg-white">
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="fa-regular fa-calendar-xmark fa-3x mb-3 opacity-50"></i>
                                <h5>Henüz hiç toplantı planlanmamış.</h5>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark">
                                    <i class="fa-solid fa-users-rectangle text-warning me-2"></i> @item.Baslik
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border px-2 py-1">
                                        <i class="fa-regular fa-clock me-1"></i>@item.Tarih.ToString("dd.MM.yyyy - HH:mm")
                                    </span>
                                </td>
                                <td class="text-muted">
                                    <i class="fa-solid fa-location-dot text-danger me-1"></i> @item.Konum
                                </td>
                                <td>
                                    @if (item.GelecekToplantiMi)
                                    {
                                        <span class="badge bg-success shadow-sm">Yaklaşan</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary shadow-sm">Tamamlandı</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group shadow-sm rounded-pill" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning text-dark px-3" title="Düzenle"><i class="fa-solid fa-pen"></i></a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white px-3" title="Detay"><i class="fa-solid fa-circle-info"></i></a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger px-3" title="Sil"><i class="fa-solid fa-trash"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>