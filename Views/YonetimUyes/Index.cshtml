@model IEnumerable<DernekSitesi.Models.YonetimUyesi>
@{
    ViewData["Title"] = "Yönetim Kadrosu";
}

<div class="container-fluid mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold" style="color: #0b2b26;"><i class="fa-solid fa-user-tie text-info me-2"></i>Yönetim Kadrosu</h2>
            <p class="text-muted">Dernek başkanı ve yönetim kurulu üyelerini buradan yönetebilirsiniz.</p>
        </div>
        <a asp-action="Create" class="btn btn-info text-white fw-bold rounded-pill px-4 shadow-sm" style="background-color: #00cec9; border:none;">
            <i class="fa-solid fa-plus me-2"></i>Yeni Üye Ekle
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted">
                    <tr>
                        <th class="px-4 py-3">Fotoğraf</th>
                        <th class="py-3">Ad Soyad</th>
                        <th class="py-3">Görev/Unvan</th>
                        <th class="py-3 text-center">Sıralama</th>
                        <th class="py-3 text-end px-4">İşlemler</th>
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="fa-solid fa-folder-open fa-3x mb-3 opacity-25"></i>
                                <h5>Henüz kimse eklenmemiş</h5>
                                <p>Sağ üstteki butondan ilk yöneticiyi ekleyerek başlayın.</p>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="px-4 py-3">
                                    @if (!string.IsNullOrEmpty(item.ResimYolu))
                                    {
                                        <img src="@item.ResimYolu" class="rounded-circle object-fit-cover shadow-sm" style="width: 50px; height: 50px;" alt="@item.AdSoyad" />
                                    }
                                    else
                                    {
                                        <div class="rounded-circle bg-secondary bg-opacity-10 d-flex align-items-center justify-content-center text-secondary shadow-sm" style="width: 50px; height: 50px;">
                                            <i class="fa-solid fa-user"></i>
                                        </div>
                                    }
                                </td>
                                <td class="py-3 fw-bold text-dark">@item.AdSoyad</td>
                                <td class="py-3"><span class="badge bg-light text-dark border px-3 py-2 rounded-pill">@item.Gorev</span></td>
                                <td class="py-3 text-center"><span class="badge bg-info text-white rounded-circle p-2">@item.Siralama</span></td>
                                <td class="py-3 text-end px-4">
                                    <div class="btn-group shadow-sm rounded-pill overflow-hidden">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary"><i class="fa-solid fa-pen"></i></a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>