@model DernekSitesi.Models.Haber
@{
    ViewData["Title"] = "Haber Detayı";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg rounded-5 overflow-hidden">

                @if (!string.IsNullOrEmpty(Model.ResimYolu))
                {
                    <div class="card-header position-relative p-0 border-0" style="height: 400px;">
                        <img src="@Model.ResimYolu" class="w-100 h-100" style="object-fit: cover;" alt="@Model.Baslik">

                        <div class="position-absolute top-0 start-0 w-100 h-100 d-flex flex-column justify-content-end p-5 text-center" style="background: linear-gradient(to top, rgba(11, 43, 38, 0.95) 0%, rgba(11, 43, 38, 0.4) 50%, transparent 100%);">
                            <h2 class="mb-3 fw-bold text-white" style="text-shadow: 0 2px 10px rgba(0,0,0,0.5);">@Model.Baslik</h2>
                            <div>
                                <span class="badge bg-white text-dark px-3 py-2 rounded-pill shadow-sm">
                                    <i class="fa-regular fa-calendar-days me-2"></i>@Model.YayinTarihi.ToString("dd MMMM yyyy HH:mm")
                                </span>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="card-header p-5 border-0 text-white text-center" style="background: linear-gradient(135deg, #0b2b26 0%, #1a4a40 100%);">
                        <i class="fa-regular fa-newspaper fa-4x mb-4 text-warning"></i>
                        <h2 class="mb-3 fw-bold">@Model.Baslik</h2>
                        <span class="badge bg-white text-dark px-3 py-2 rounded-pill shadow-sm">
                            <i class="fa-regular fa-calendar-days me-2"></i>@Model.YayinTarihi.ToString("dd MMMM yyyy HH:mm")
                        </span>
                    </div>
                }

                <div class="card-body p-5">
                    <p class="text-dark" style="font-size: 1.15rem; line-height: 1.8; white-space: pre-wrap;">@Model.Icerik</p>
                </div>

                <div class="card-footer bg-light border-0 p-4 text-center">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-dark fw-bold px-5 py-2 rounded-pill w-100" style="max-width: 300px;">
                        <i class="fa-solid fa-arrow-left me-2"></i>Ana Sayfaya Dön
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>