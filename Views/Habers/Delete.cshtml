@model DernekSitesi.Models.Haber
@{
    ViewData["Title"] = "Haberi Sil";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden text-center">
                <div class="card-header bg-danger text-white p-4 border-0">
                    <i class="fa-solid fa-triangle-exclamation fa-4x mb-3 mt-2"></i>
                    <h3 class="fw-bold mb-0">Dikkat! Haberi Silmek Üzeresiniz</h3>
                </div>
                <div class="card-body p-5">
                    <h4 class="fw-bold text-dark mb-3">@Model.Baslik</h4>
                    <p class="text-muted mb-4">Bu haberi silmek istediğinize emin misiniz? Bu işlem geri alınamaz ve haber ana sayfadan anında kaldırılacaktır.</p>

                    <div class="bg-light p-3 rounded-3 mb-4 text-start border">
                        <small class="text-muted fw-bold d-block mb-1">EKLENME TARİHİ</small>
                        <span class="fw-bold text-dark">@Model.YayinTarihi.ToString("dd.MM.yyyy HH:mm")</span>
                    </div>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-center gap-3 mt-4">
                            <a asp-action="Index" class="btn btn-light fw-bold px-4 py-3 rounded-pill">Vazgeç ve Dön</a>
                            <button type="submit" class="btn btn-danger fw-bold px-4 py-3 rounded-pill shadow-sm">
                                <i class="fa-solid fa-trash me-2"></i>Evet, Kalıcı Olarak Sil
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>