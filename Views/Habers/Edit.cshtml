@model DernekSitesi.Models.Haber
@{
    ViewData["Title"] = "Haber Düzenle";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header text-white p-4 border-0" style="background: linear-gradient(135deg, #0984e3 0%, #74b9ff 100%);">
                    <h3 class="mb-0 fw-bold"><i class="fa-solid fa-pen-to-square me-2"></i>Haber Düzenle</h3>
                </div>
                <div class="card-body p-5">
                    <form asp-action="Edit">
                        <input type="hidden" asp-for="Id" />
                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted small">HABER BAŞLIĞI</label>
                            <input asp-for="Baslik" class="form-control form-control-lg bg-light border-0 shadow-sm" />
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold text-muted small">HABER İÇERİĞİ</label>
                            <textarea asp-for="Icerik" class="form-control form-control-lg bg-light border-0 shadow-sm" rows="6"></textarea>
                        </div>
                        <div class="mb-5">
                            <label class="form-label fw-bold text-muted small">YAYIN TARİHİ</label>
                            <input asp-for="YayinTarihi" class="form-control form-control-lg bg-light border-0 shadow-sm" />
                        </div>
                        <div class="d-flex justify-content-between align-items-center mt-2">
                            <a asp-action="Index" class="btn btn-light fw-bold px-4 py-2 rounded-pill">İptal Et</a>
                            <button type="submit" class="btn btn-primary fw-bold px-5 py-2 rounded-pill shadow-sm">
                                <i class="fa-solid fa-check me-2"></i>Değişiklikleri Kaydet
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>