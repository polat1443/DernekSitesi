@model DernekSitesi.Models.Haber

@{
    ViewData["Title"] = "Yeni Haber Ekle";
}

<style>
    .form-card {
        background: #ffffff;
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.05);
        border: 1px solid rgba(0,0,0,0.05);
        padding: 40px;
        max-width: 800px;
        margin: 0 auto;
    }

    .form-control {
        border-radius: 12px;
        padding: 14px 20px;
        border: 2px solid #f0f2f5;
        background-color: #f8f9fa;
        transition: all 0.3s ease;
        font-weight: 500;
    }

        .form-control:focus {
            border-color: #0984e3;
            box-shadow: 0 0 0 0.2rem rgba(9, 132, 227, 0.15);
            background-color: #ffffff;
        }

    .form-label {
        font-weight: 700;
        color: #2d3436;
        margin-bottom: 8px;
        font-size: 0.95rem;
    }
    /* Haberler için Mavi Buton Tasarımı */
    .btn-save {
        background: linear-gradient(135deg, #0984e3 0%, #74b9ff 100%);
        color: white !important;
        border: none;
        padding: 14px 35px;
        border-radius: 12px;
        font-weight: 700;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(9, 132, 227, 0.3);
    }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(9, 132, 227, 0.5);
        }

    .btn-back {
        background: #f1f2f6;
        color: #2f3542 !important;
        border: none;
        padding: 14px 25px;
        border-radius: 12px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .btn-back:hover {
            background: #dfe4ea;
        }
</style>

<div class="container mt-4 mb-5">
    <div class="form-card">
        <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
            <div class="p-3 rounded-4 me-3" style="background: rgba(9, 132, 227, 0.15); color: #0984e3;">
                <i class="fa-solid fa-newspaper fa-2x"></i>
            </div>
            <div>
                <h2 class="fw-bold mb-0 text-dark">Yeni Haber Yayınla</h2>
                <p class="text-muted mb-0">Dernekle ilgili son gelişmeleri ve duyuruları buradan paylaşın.</p>
            </div>
        </div>

        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

            <div class="row g-4">
                <div class="col-md-12">
                    <label asp-for="Baslik" class="form-label"><i class="fa-solid fa-heading text-primary me-2"></i>Haber Başlığı</label>
                    <input asp-for="Baslik" class="form-control" placeholder="Örn: Derneğimizden İhtiyaç Sahiplerine Yardım Eli" />
                    <span asp-validation-for="Baslik" class="text-danger fw-bold" style="font-size: 0.85rem;"></span>
                </div>

                <div class="col-md-12">
                    <label asp-for="Icerik" class="form-label"><i class="fa-solid fa-align-left text-info me-2"></i>Haber Detayı</label>
                    <textarea asp-for="Icerik" class="form-control" rows="6" placeholder="Haberin tüm detaylarını, neler yapıldığını buraya yazabilirsiniz..."></textarea>
                    <span asp-validation-for="Icerik" class="text-danger fw-bold" style="font-size: 0.85rem;"></span>
                </div>

                <div class="col-md-12">
                    <label class="form-label"><i class="fa-solid fa-image text-success me-2"></i>Haber Görseli</label>
                    <input type="file" name="resimDosyasi" class="form-control" accept="image/*" />
                    <small class="text-muted fw-bold d-block mt-2"><i class="fa-solid fa-circle-info me-1"></i>Habere kapak olacak bir resim seçin (JPG, PNG). İsteğe bağlıdır.</small>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-5 pt-3 border-top">
                <a asp-action="Index" class="btn btn-back">
                    <i class="fa-solid fa-arrow-left me-2"></i>Listeye Dön
                </a>
                <button type="submit" class="btn btn-save">
                    <i class="fa-solid fa-share-from-square me-2"></i>Haberi Yayınla
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}