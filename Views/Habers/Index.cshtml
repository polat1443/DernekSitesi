@model IEnumerable<DernekSitesi.Models.Haber>
@{
    ViewData["Title"] = "Haber Listesi";
}

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4 p-4 bg-white rounded-4 shadow-sm border" style="border-color: #f1f2f6 !important;">
        <div class="d-flex align-items-center">
            <div class="p-3 rounded-circle me-3" style="background: rgba(9, 132, 227, 0.15); color: #0984e3;">
                <i class="fa-solid fa-newspaper fa-2x"></i>
            </div>
            <div>
                <h2 class="fw-bold mb-0 text-dark">Haber Yönetimi</h2>
                <p class="text-muted mb-0">Sistemdeki tüm haberleri buradan yönetebilirsiniz.</p>
            </div>
        </div>
        <a asp-action="Create" class="btn btn-primary fw-bold px-4 py-2 rounded-pill shadow-sm">
            <i class="fa-solid fa-plus me-2"></i>Yeni Haber Ekle
        </a>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="text-white" style="background-color: #2d3436;">
                    <tr>
                        <th class="py-3 ps-4">HABER BAŞLIĞI</th>
                        <th>İÇERİK ÖZETİ</th>
                        <th>YAYIN TARİHİ</th>
                        <th class="text-end pe-4">İŞLEMLER</th>
                    </tr>
                </thead>
                <tbody class="bg-white">
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <i class="fa-regular fa-folder-open fa-3x mb-3 opacity-50"></i>
                                <h5>Henüz hiç haber eklenmemiş.</h5>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark">
                                    <i class="fa-solid fa-bolt text-warning me-2"></i> @item.Baslik
                                </td>
                                <td class="text-muted">
                                    @(item.Icerik != null && item.Icerik.Length > 50 ? item.Icerik.Substring(0, 50) + "..." : item.Icerik)
                                </td>
                                <td>
                                    <span class="badge bg-light text-dark border"><i class="fa-regular fa-calendar me-1"></i>@item.YayinTarihi.ToString("dd.MM.yyyy")</span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group shadow-sm rounded-pill" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary px-3" title="Düzenle"><i class="fa-solid fa-pen"></i></a>
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white px-3" title="Detay"><i class="fa-solid fa-circle-info"></i></a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger px-3" title="Sil"><i class="fa-solid fa-trash"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>