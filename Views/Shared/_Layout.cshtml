<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Dernek Yönetimi</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        /* İŞTE O GERÇEK DERNEK YEŞİLİ */
        .navbar-custom {
            background-color: #0b2b26 !important; /* Ekran görüntündeki o koyu, tok yeşil */
            border-bottom: 3px solid #f39c12; /* Altına ince bir altın/sarı çizgi */
        }

        .nav-link {
            color: rgba(255,255,255,0.9) !important;
            font-weight: 600;
            transition: 0.3s;
            text-transform: uppercase;
            font-size: 0.9rem;
            letter-spacing: 0.5px;
        }

            .nav-link:hover {
                color: #f39c12 !important; /* Üzerine gelince sarı parlasın */
            }

        .dropdown-menu {
            background-color: #ffffff;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.15);
            border: none;
            overflow: hidden;
        }

        .dropdown-item:hover {
            background-color: #f8f9fa;
            color: #0b2b26 !important;
        }

        .footer-custom {
            background-color: #1a1a1a;
            color: white;
            padding: 40px 0;
            border-top: 5px solid #0b2b26;
        }
    </style>
</head>
<body style="background-color: #f4f7f6;">
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark navbar-custom mb-4 p-3 shadow-sm">
            <div class="container-fluid px-lg-5">
                <a class="navbar-brand fw-bold text-white d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <img src="https://cdn-icons-png.flaticon.com/512/3233/3233514.png" width="35" class="me-2" style="filter: invert(1);">
                    <span style="letter-spacing: 1px;">DERNEK YÖNETİMİ</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 align-items-center">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="fa-solid fa-house-chimney me-1 small"></i> ANA SAYFA
                            </a>
                        </li>

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="hakkimizdaMenu" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="fa-solid fa-bars-staggered me-1 small"></i> HAKKIMIZDA
                            </a>
                            <ul class="dropdown-menu mt-2 p-2 shadow border-0">
                                <li>
                                    <a class="dropdown-item py-2 fw-bold text-dark" asp-controller="Home" asp-action="Vizyon">
                                        <i class="fa-solid fa-eye text-primary me-2"></i>Vizyonumuz
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item py-2 fw-bold text-dark" asp-controller="Home" asp-action="Misyon">
                                        <i class="fa-solid fa-hand-holding-heart text-success me-2"></i>Misyonumuz
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a class="dropdown-item py-2 fw-bold text-dark" asp-controller="Home" asp-action="Galeri">
                                        <i class="fa-solid fa-images text-info me-2"></i>Etkinlik Galerisi
                                    </a>
                                </li>
                            </ul>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="btn btn-outline-warning rounded-pill px-4 fw-bold btn-sm" asp-controller="Admin" asp-action="Index">
                                <i class="fa-solid fa-user-lock me-2"></i> YÖNETİCİ PANELİ
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-custom mt-5">
        <div class="container text-center">
            <div class="mb-3">
                <i class="fa-solid fa-handshake-angle fa-2x text-warning opacity-75"></i>
            </div>
            <h5 class="fw-bold mb-2" style="letter-spacing: 1px;">GELECEĞİ BİRLİKTE İNŞA EDİYORUZ</h5>
            <div class="opacity-50 small">
                <p class="mb-0">© @DateTime.Now.Year - Tüm Hakları Saklıdır.</p>
                <p class="mb-0 fw-bold text-warning">Polat Bilir Geliştiriciliği ile Hazırlanmıştır.</p>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>