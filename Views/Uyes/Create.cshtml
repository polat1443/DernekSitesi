@model DernekSitesi.Models.Uye

@{
    ViewData["Title"] = "Yeni Üye Ekle";
}

<style>
    .form-card {
        background: #ffffff;
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.05);
        border: 1px solid rgba(0,0,0,0.05);
        padding: 40px;
        max-width: 800px;
        margin: 0 auto;
    }

    .form-control, .form-select {
        border-radius: 12px;
        padding: 14px 20px;
        border: 2px solid #f0f2f5;
        background-color: #f8f9fa;
        transition: all 0.3s ease;
        font-weight: 500;
    }

        .form-control:focus, .form-select:focus {
            border-color: #00b894;
            box-shadow: 0 0 0 0.2rem rgba(0, 184, 148, 0.15);
            background-color: #ffffff;
        }

    .form-label {
        font-weight: 700;
        color: #2d3436;
        margin-bottom: 8px;
        font-size: 0.95rem;
    }

    .btn-save {
        background: linear-gradient(135deg, #00b894 0%, #55efc4 100%);
        color: white !important;
        border: none;
        padding: 14px 35px;
        border-radius: 12px;
        font-weight: 700;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(0, 184, 148, 0.3);
    }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(0, 184, 148, 0.5);
        }

    .btn-back {
        background: #f1f2f6;
        color: #2f3542 !important;
        border: none;
        padding: 14px 25px;
        border-radius: 12px;
        font-weight: 600;
        transition: all 0.3s ease;
        text-decoration: none;
    }

        .btn-back:hover {
            background: #dfe4ea;
        }

    .form-check-input {
        width: 1.5em;
        height: 1.5em;
        cursor: pointer;
    }

        .form-check-input:checked {
            background-color: #00b894;
            border-color: #00b894;
        }

    .form-check-label {
        font-size: 1.1rem;
        padding-top: 4px;
        padding-left: 8px;
        cursor: pointer;
    }
</style>

<div class="container mt-5 mb-5">
    <div class="form-card">
        <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
            <div class="p-3 rounded-4 me-3" style="background: rgba(0, 184, 148, 0.15); color: #00b894;">
                <i class="fa-solid fa-user-plus fa-2x"></i>
            </div>
            <div>
                <h2 class="fw-bold mb-0 text-dark">Aramıza Katıl</h2>
                <p class="text-muted mb-0">Derneğimize üye olmak için aşağıdaki bilgileri eksiksiz doldurun.</p>
            </div>
        </div>

        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

            <div class="row g-4">
                <div class="col-md-12">
                    <label asp-for="AdSoyad" class="form-label"><i class="fa-regular fa-id-badge text-primary me-2"></i>Ad Soyad</label>
                    <input asp-for="AdSoyad" class="form-control" placeholder="Örn: Polat Bilir" autocomplete="off" />
                    <span asp-validation-for="AdSoyad" class="text-danger fw-bold" style="font-size: 0.85rem;"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Email" class="form-label"><i class="fa-solid fa-envelope text-secondary me-2"></i>E-Posta Adresi</label>
                    <input asp-for="Email" class="form-control" type="email" placeholder="uye@derneksitesi.com" autocomplete="off" required />
                    <span asp-validation-for="Email" class="text-danger fw-bold" style="font-size: 0.85rem;"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Sifre" class="form-label"><i class="fa-solid fa-key text-dark me-2"></i>Giriş Şifresi</label>
                    <input asp-for="Sifre" class="form-control" type="text" placeholder="Örn: 12345" autocomplete="off" required />
                    <span asp-validation-for="Sifre" class="text-danger fw-bold" style="font-size: 0.85rem;"></span>
                </div>

                <div class="col-md-6">
                    <label class="form-label"><i class="fa-solid fa-camera text-primary me-2"></i>Profil Fotoğrafı</label>
                    <input type="file" name="resimDosyasi" class="form-control" accept="image/*" />
                </div>

                <div class="col-md-6">
                    <label asp-for="Meslek" class="form-label"><i class="fa-solid fa-briefcase text-info me-2"></i>Meslek / Uzmanlık</label>
                    <input asp-for="Meslek" class="form-control" placeholder="Örn: Yazılım Geliştirici" />
                    <span asp-validation-for="Meslek" class="text-danger fw-bold" style="font-size: 0.85rem;"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="KanGrubu" class="form-label"><i class="fa-solid fa-droplet text-danger me-2"></i>Kan Grubu</label>
                    <select asp-for="KanGrubu" class="form-select">
                        <option value="">Seçiniz...</option>
                        <option value="A Rh+">A Rh+</option>
                        <option value="A Rh-">A Rh-</option>
                        <option value="B Rh+">B Rh+</option>
                        <option value="B Rh-">B Rh-</option>
                        <option value="0 Rh+">0 Rh+</option>
                        <option value="0 Rh-">0 Rh-</option>
                        <option value="AB Rh+">AB Rh+</option>
                        <option value="AB Rh-">AB Rh-</option>
                    </select>
                    <span asp-validation-for="KanGrubu" class="text-danger fw-bold" style="font-size: 0.85rem;"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Telefon" class="form-label"><i class="fa-solid fa-phone text-success me-2"></i>Telefon Numarası</label>
                    <input asp-for="Telefon" class="form-control" placeholder="Örn: 0555 123 45 67" />
                    <span asp-validation-for="Telefon" class="text-danger fw-bold" style="font-size: 0.85rem;"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="KayitTarihi" class="form-label"><i class="fa-regular fa-calendar-days text-warning me-2"></i>Kayıt Tarihi</label>
                    <input asp-for="KayitTarihi" class="form-control" type="date" />
                    <span asp-validation-for="KayitTarihi" class="text-danger fw-bold" style="font-size: 0.85rem;"></span>
                </div>

                <div class="col-md-12 d-none">
                    <input class="form-check-input" asp-for="AktifMi" checked />
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mt-5 pt-3 border-top">
                <a href="/" class="btn btn-back">
                    <i class="fa-solid fa-arrow-left me-2"></i>Ana Sayfaya Dön
                </a>
                <button type="submit" class="btn btn-save">
                    <i class="fa-solid fa-check-double me-2"></i>Kaydı Tamamla
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}