@model DernekSitesi.Models.Uye

@{
    ViewData["Title"] = "Üye Sil";
}

<style>
    .delete-card {
        background: #ffffff;
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(214, 48, 49, 0.15); /* Hafif kırmızımsı gölge */
        border: 1px solid rgba(214, 48, 49, 0.1);
        padding: 40px;
        max-width: 600px;
        margin: 0 auto;
        text-align: center;
    }

    .warning-icon {
        color: #d63031;
        background: rgba(214, 48, 49, 0.1);
        width: 80px;
        height: 80px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
    }

    .profile-img {
        width: 100px;
        height: 100px;
        object-fit: cover;
        border: 4px solid #ffffff;
        border-radius: 50%;
        margin-bottom: 15px;
    }

    .btn-delete {
        background: linear-gradient(135deg, #d63031 0%, #ff7675 100%);
        color: white !important;
        border: none;
        padding: 14px 30px;
        border-radius: 12px;
        font-weight: 700;
        letter-spacing: 1px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(214, 48, 49, 0.3);
    }

        .btn-delete:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(214, 48, 49, 0.5);
        }

    .btn-back {
        background: #f1f2f6;
        color: #2f3542 !important;
        border: none;
        padding: 14px 25px;
        border-radius: 12px;
        font-weight: 600;
        transition: all 0.3s ease;
        text-decoration: none;
    }

        .btn-back:hover {
            background: #dfe4ea;
        }

    .member-info {
        background: #f8f9fa;
        border-radius: 15px;
        padding: 25px 20px;
        margin: 25px 0;
        border: 1px solid #eeeeee;
    }
</style>

<div class="container mt-5 mb-5">
    <div class="delete-card">
        <div class="warning-icon">
            <i class="fa-solid fa-triangle-exclamation fa-3x"></i>
        </div>

        <h2 class="fw-bold text-dark mb-2">Bu Üyeyi Silmek İstediğinize Emin Misiniz?</h2>
        <p class="text-danger fw-bold opacity-75">Bu işlem geri alınamaz. Sistemdeki tüm erişimi kesilecektir.</p>

        <div class="member-info shadow-sm">
            @if (!string.IsNullOrEmpty(Model.ProfilFotografi))
            {
                <img src="@Model.ProfilFotografi" class="profile-img shadow-sm" alt="@Model.AdSoyad" />
            }
            else
            {
                <div class="profile-img shadow-sm d-inline-flex align-items-center justify-content-center bg-white text-muted mx-auto">
                    <i class="fa-solid fa-user fa-3x"></i>
                </div>
            }
            <h4 class="fw-bold text-dark mb-1">@Model.AdSoyad</h4>
            <div class="text-muted mb-3"><i class="fa-solid fa-envelope me-2"></i>@Model.Email</div>

            <div>
                <span class="badge @(Model.AktifMi ? "bg-success" : "bg-secondary") rounded-pill px-3 py-2 shadow-sm">
                    @(Model.AktifMi ? "Aktif Üye" : "Pasif Üye")
                </span>
                <span class="badge bg-info rounded-pill px-3 py-2 shadow-sm ms-2">
                    <i class="fa-solid fa-briefcase me-1"></i> @Model.Meslek
                </span>
            </div>
        </div>

        <form asp-action="Delete" class="mt-4">
            <input type="hidden" asp-for="Id" />

            <div class="d-flex justify-content-between align-items-center">
                <a asp-action="Index" class="btn btn-back">
                    <i class="fa-solid fa-arrow-left me-2"></i>Vazgeç, Geri Dön
                </a>
                <button type="submit" class="btn btn-delete">
                    <i class="fa-solid fa-trash-can me-2"></i>Evet, Kalıcı Olarak Sil
                </button>
            </div>
        </form>
    </div>
</div>