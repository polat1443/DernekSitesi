@{
    ViewData["Title"] = "Erişim Engellendi";
    Layout = null; // Admin paneli menüleri görünmesin diye Layout'u iptal ediyoruz
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Erişim Engellendi - Dernek Yönetimi</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            background-color: #2d3436;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .error-card {
            background: #ffffff;
            border-radius: 20px;
            padding: 50px 40px;
            text-align: center;
            max-width: 500px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.2);
            border-top: 5px solid #d63031;
        }

        .error-icon {
            font-size: 5rem;
            color: #d63031;
            margin-bottom: 20px;
        }

        .btn-home {
            background: #2d3436;
            color: white;
            padding: 12px 30px;
            border-radius: 10px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s ease;
        }

            .btn-home:hover {
                background: #d63031;
                color: white;
            }
    </style>
</head>
<body>

    <div class="error-card">
        <div class="error-icon">
            <i class="fa-solid fa-shield-halved"></i>
        </div>
        <h2 class="fw-bold text-dark mb-3">Dur Yolcu!</h2>
        <h5 class="text-danger fw-bold mb-4">Erişim Engellendi (403)</h5>
        <p class="text-muted mb-4">
            Giriş yaptığınız hesabın <strong>Yönetim Paneli'ne</strong> girmeye yetkisi bulunmamaktadır. Bu alana sadece dernek yöneticileri (Admin) erişebilir.
        </p>

        <div class="d-grid gap-2">
            <a href="/" class="btn btn-home">
                <i class="fa-solid fa-house me-2"></i>Ana Sayfaya Dön
            </a>
            <a href="/Admin/Logout" class="btn btn-light border fw-bold text-muted mt-2">
                <i class="fa-solid fa-right-from-bracket me-2"></i>Farklı Bir Hesapla Gir
            </a>
        </div>
    </div>

</body>
</html>