@{
    ViewData["Title"] = "Sistem Kontrol Paneli";
}

<style>
    .admin-header {
        background: linear-gradient(135deg, #2b5876 0%, #4e4376 100%);
        color: white;
        border-radius: 20px;
        padding: 40px 30px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        margin-top: -10px;
        position: relative;
    }

    .logout-btn {
        position: absolute;
        top: 20px;
        right: 20px;
        background: rgba(255, 255, 255, 0.15);
        color: white;
        border: 1px solid rgba(255, 255, 255, 0.3);
        padding: 8px 18px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.3s;
    }

        .logout-btn:hover {
            background: rgba(214, 48, 49, 0.8);
            color: white;
            border-color: transparent;
        }

    .admin-card {
        background: #ffffff;
        border-radius: 16px;
        border: none;
        transition: all 0.3s ease;
        box-shadow: 0 8px 25px rgba(0,0,0,0.04);
        overflow: hidden;
    }

        .admin-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        }

    .icon-box {
        width: 70px;
        height: 70px;
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        margin-bottom: 20px;
    }

    .bg-light-primary {
        background: rgba(9, 132, 227, 0.1);
        color: #0984e3;
    }

    .bg-light-warning {
        background: rgba(253, 203, 110, 0.1);
        color: #e1b12c;
    }

    .bg-light-success {
        background: rgba(0, 184, 148, 0.1);
        color: #00b894;
    }

    /* YENİ EKLENEN İSTATİSTİK KARTLARI STİLLERİ */
    .stat-card {
        border-radius: 20px;
        border: none;
        color: white;
        overflow: hidden;
        position: relative;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.15);
        }

    .stat-icon {
        position: absolute;
        right: -20px;
        bottom: -20px;
        font-size: 8rem;
        opacity: 0.2;
        transform: rotate(-15deg);
    }

    .bg-gradient-primary {
        background: linear-gradient(135deg, #0984e3 0%, #74b9ff 100%);
    }

    .bg-gradient-success {
        background: linear-gradient(135deg, #00b894 0%, #55efc4 100%);
    }

    .bg-gradient-warning {
        background: linear-gradient(135deg, #fdcb6e 0%, #ffeaa7 100%);
    }

    .bg-gradient-danger {
        background: linear-gradient(135deg, #d63031 0%, #ff7675 100%);
    }
</style>

<div class="admin-header mb-5 text-center">
    <a href="/Admin/Logout" class="logout-btn">
        <i class="fa-solid fa-right-from-bracket me-2"></i>Çıkış Yap
    </a>
    <div class="display-4 mb-3"><i class="fa-solid fa-user-shield text-warning"></i></div>
    <h1 class="fw-bold">Yönetim Paneline Hoş Geldiniz</h1>
    <p class="lead opacity-75">Sitenin tüm içeriklerini, üyelerini ve toplantılarını buradan güvenle yönetebilirsiniz.</p>
</div>

<h4 class="fw-bold text-dark mb-4"><i class="fa-solid fa-chart-line text-primary me-2"></i>Sistem Özeti</h4>
<div class="row g-4 mb-5 pb-3 border-bottom">
    <div class="col-xl-3 col-md-6">
        <div class="card stat-card bg-gradient-primary shadow-sm h-100 p-4">
            <div class="stat-icon"><i class="fa-solid fa-users"></i></div>
            <h5 class="fw-bold mb-1 opacity-75">Toplam Üye</h5>
            <h1 class="display-4 fw-bold mb-0">@ViewBag.ToplamUye</h1>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card stat-card bg-gradient-success shadow-sm h-100 p-4">
            <div class="stat-icon"><i class="fa-solid fa-user-check"></i></div>
            <h5 class="fw-bold mb-1 opacity-75">Aktif Üyeler</h5>
            <h1 class="display-4 fw-bold mb-0">@ViewBag.AktifUye</h1>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card stat-card bg-gradient-warning shadow-sm h-100 p-4">
            <div class="stat-icon"><i class="fa-solid fa-newspaper"></i></div>
            <h5 class="fw-bold mb-1 opacity-75 text-dark">Yayınlanan Haber</h5>
            <h1 class="display-4 fw-bold mb-0 text-dark">@ViewBag.ToplamHaber</h1>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card stat-card bg-gradient-danger shadow-sm h-100 p-4">
            <div class="stat-icon"><i class="fa-solid fa-envelope-open-text"></i></div>
            <h5 class="fw-bold mb-1 opacity-75">Yeni Mesajlar</h5>
            <h1 class="display-4 fw-bold mb-0">@ViewBag.OkunmamisMesaj</h1>
        </div>
    </div>
</div>

<h4 class="fw-bold text-dark mb-4"><i class="fa-solid fa-layer-group text-secondary me-2"></i>Yönetim Modülleri</h4>
<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="card admin-card p-4 h-100 border-top border-4 border-warning">
            <div class="card-body">
                <div class="icon-box bg-light-warning"><i class="fa-solid fa-users-gear"></i></div>
                <h3 class="fw-bold text-dark mb-3">Toplantı Yönetimi</h3>
                <p class="text-muted mb-4">Dernek toplantılarını planlayın, geçmiş toplantıları düzenleyin veya silin.</p>
                <a href="/Toplantis" class="btn btn-warning text-dark fw-bold px-4 rounded-pill">
                    Modüle Git <i class="fa-solid fa-arrow-right ms-2"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card admin-card p-4 h-100 border-top border-4 border-primary">
            <div class="card-body">
                <div class="icon-box bg-light-primary"><i class="fa-solid fa-newspaper"></i></div>
                <h3 class="fw-bold text-dark mb-3">Haber Yönetimi</h3>
                <p class="text-muted mb-4">Derneğinizle ilgili son gelişmeleri, duyuruları ve haberleri sisteme ekleyin.</p>
                <a href="/Habers" class="btn btn-primary fw-bold px-4 rounded-pill">
                    Modüle Git <i class="fa-solid fa-arrow-right ms-2"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card admin-card p-4 h-100 border-top border-4 border-success">
            <div class="card-body">
                <div class="icon-box bg-light-success"><i class="fa-solid fa-id-card-clip"></i></div>
                <h3 class="fw-bold text-dark mb-3">Üye Yönetimi</h3>
                <p class="text-muted mb-4">Dernek üyelerini kaydedin, aidat/kan grubu bilgilerini güncelleyin veya silin.</p>
                <a href="/Uyes" class="btn btn-success fw-bold px-4 rounded-pill" style="background: #00b894; border:none;">
                    Modüle Git <i class="fa-solid fa-arrow-right ms-2"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card admin-card p-4 h-100 border-top border-4 border-danger">
            <div class="card-body">
                <div class="icon-box" style="background: rgba(214, 48, 49, 0.1); color: #d63031;"><i class="fa-solid fa-envelope-open-text"></i></div>
                <h3 class="fw-bold text-dark mb-3">Gelen Kutusu</h3>
                <p class="text-muted mb-4">Sitedeki iletişim formundan gelen ziyaretçi ve üye mesajlarını okuyun, yönetin.</p>
                <a href="/Admin/GelenKutusu" class="btn btn-danger fw-bold px-4 rounded-pill" style="border:none;">
                    Mesajları Oku <i class="fa-solid fa-arrow-right ms-2"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card admin-card p-4 h-100 border-top border-4" style="border-color: #9b59b6 !important;">
            <div class="card-body">
                <div class="icon-box" style="background: rgba(155, 89, 182, 0.1); color: #9b59b6;"><i class="fa-solid fa-images"></i></div>
                <h3 class="fw-bold text-dark mb-3">Galeri Yönetimi</h3>
                <p class="text-muted mb-4">Dernek etkinliklerine ait fotoğrafları sisteme yükleyin, albümü düzenleyin veya eski görselleri silin.</p>
                <a asp-controller="GaleriGorsels" asp-action="Index" class="btn text-white fw-bold px-4 rounded-pill" style="background-color: #9b59b6; border:none;">
                    Modüle Git <i class="fa-solid fa-arrow-right ms-2"></i>
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card admin-card p-4 h-100 border-top border-4" style="border-color: #00cec9 !important;">
            <div class="card-body">
                <div class="icon-box" style="background: rgba(0, 206, 201, 0.1); color: #00cec9;"><i class="fa-solid fa-user-tie"></i></div>
                <h3 class="fw-bold text-dark mb-3">Yönetim Kadrosu</h3>
                <p class="text-muted mb-4">Dernek başkanı ve yönetim kurulu üyelerini ekleyin, unvanlarını güncelleyin veya silin.</p>
                <a asp-controller="YonetimUyes" asp-action="Index" class="btn text-white fw-bold px-4 rounded-pill" style="background-color: #00cec9; border:none;">
                    Modüle Git <i class="fa-solid fa-arrow-right ms-2"></i>
                </a>
            </div>
        </div>
    </div>
</div>