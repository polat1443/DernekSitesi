@model IEnumerable<DernekSitesi.Models.GaleriGorsel>

@{
    ViewData["Title"] = "Galeri Yönetimi";
}

<div class="container mt-4 mb-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-center bg-white p-4 rounded-4 shadow-sm border-start border-5 mb-4" style="border-color: #9b59b6 !important;">
        <div class="d-flex align-items-center mb-3 mb-md-0">
            <div class="p-3 rounded-circle me-3" style="background-color: rgba(155, 89, 182, 0.1); color: #9b59b6;">
                <i class="fa-solid fa-images fa-2x"></i>
            </div>
            <div>
                <h2 class="fw-bold mb-0 text-dark">Galeri Yönetimi</h2>
                <p class="text-muted mb-0">Dernek etkinlik fotoğraflarını buradan yönetebilirsiniz.</p>
            </div>
        </div>
        <div>
            <a asp-action="Create" class="btn text-white rounded-pill px-4 py-3 fw-bold shadow-sm" style="background-color: #9b59b6; transition: all 0.3s;">
                <i class="fa-solid fa-plus me-2"></i>Yeni Görsel Yükle
            </a>
            <a asp-controller="Admin" asp-action="Index" class="btn btn-light rounded-pill px-4 py-3 fw-bold ms-2 shadow-sm border">
                <i class="fa-solid fa-arrow-left me-2"></i>Geri Dön
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert bg-white border-0 shadow-sm rounded-4 p-5 text-center mt-4">
            <div class="mb-4">
                <i class="fa-regular fa-folder-open fa-4x" style="color: #dfe6e9;"></i>
            </div>
            <h4 class="fw-bold text-dark mb-2">Henüz Görsel Yüklenmemiş</h4>
            <p class="text-muted mb-4">Galeriniz şu an boş. Yukarıdaki "Yeni Görsel Yükle" butonuna tıklayarak ilk fotoğrafınızı ekleyebilirsiniz.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-lg-4 col-md-6">
                    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden transition-hover" style="transition: transform 0.3s ease;">

                        <div class="position-relative">
                            @if (!string.IsNullOrEmpty(item.ResimYolu))
                            {
                                <img src="@item.ResimYolu" class="w-100" style="height: 220px; object-fit: cover;" alt="@item.Baslik" />
                            }
                            else
                            {
                                <div class="w-100 d-flex align-items-center justify-content-center" style="height: 220px; background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);">
                                    <i class="fa-solid fa-image text-white fa-4x opacity-50"></i>
                                </div>
                            }

                            <div class="position-absolute top-0 end-0 m-3">
                                <span class="badge bg-dark bg-opacity-75 rounded-pill px-3 py-2 shadow-sm">
                                    <i class="fa-regular fa-calendar-days me-1"></i> @item.EklenmeTarihi.ToString("dd.MM.yyyy")
                                </span>
                            </div>
                        </div>

                        <div class="card-body">
                            <h5 class="fw-bold text-dark mb-0">@item.Baslik</h5>
                        </div>

                        <div class="card-footer bg-white border-top p-3 d-flex justify-content-between align-items-center">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm rounded-pill fw-bold px-4">
                                <i class="fa-solid fa-pen-to-square me-1"></i> Düzenle
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm rounded-pill fw-bold px-4">
                                <i class="fa-solid fa-trash me-1"></i> Sil
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .transition-hover:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
    }
</style>