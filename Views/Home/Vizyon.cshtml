@{
    ViewData["Title"] = "Vizyonumuz";
}

<div class="container mt-5 mb-5">
    <div class="card border-0 shadow-lg rounded-5 overflow-hidden">
        <div class="row g-0">
            <div class="col-lg-5 d-none d-lg-block" style="background: url('https://images.unsplash.com/photo-1519389950473-47ba0277781c?q=80&w=2070&auto=format&fit=crop') center/cover;">
            </div>
            <div class="col-lg-7 p-5 bg-white">
                <div class="d-flex align-items-center mb-4">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-4 me-3 text-primary">
                        <i class="fa-solid fa-eye fa-2x"></i>
                    </div>
                    <h1 class="fw-bold mb-0" style="color: #0b2b26;">Vizyonumuz</h1>
                </div>

                <p class="lead text-muted mb-4" style="line-height: 1.8;">
                    Geleceğin dünyasında yardımlaşma ve dayanışmanın dijital ve fiziksel her alanda öncüsü olmayı hedefliyoruz.
                </p>

                <div class="bg-light p-4 rounded-4 border-start border-4 border-primary mb-4">
                    <h5 class="fw-bold">Hedefimiz Ne?</h5>
                    <p class="mb-0 text-secondary">
                        Toplumun her kesimine ulaşan, şeffaflığı ilke edinmiş ve teknolojiyle harmanlanmış bir dernek yapısı kurarak ulusal çapta model alınan bir kurum olmaktır.
                    </p>
                </div>

                <ul class="list-unstyled">
                    <li class="mb-3"><i class="fa-solid fa-check-circle text-success me-2"></i> Yenilikçi projelerle toplumsal fayda.</li>
                    <li class="mb-3"><i class="fa-solid fa-check-circle text-success me-2"></i> Sürdürülebilir kalkınma desteği.</li>
                    <li><i class="fa-solid fa-check-circle text-success me-2"></i> Küresel düzeyde tanınan bir dernek kimliği.</li>
                </ul>

                <a asp-action="Misyon" class="btn btn-outline-primary rounded-pill px-4 mt-4 fw-bold">Misyonumuza Göz At <i class="fa-solid fa-arrow-right ms-2"></i></a>
            </div>
        </div>
    </div>
</div>