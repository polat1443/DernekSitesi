@{
    ViewData["Title"] = "Misyonumuz";
}

<div class="container mt-5 mb-5">
    <div class="card border-0 shadow-lg rounded-5 overflow-hidden">
        <div class="row g-0">
            <div class="col-lg-7 p-5 bg-white order-2 order-lg-1">
                <div class="d-flex align-items-center mb-4">
                    <div class="bg-success bg-opacity-10 p-3 rounded-4 me-3 text-success">
                        <i class="fa-solid fa-bullseye fa-2x"></i>
                    </div>
                    <h1 class="fw-bold mb-0" style="color: #0b2b26;">Misyonumuz</h1>
                </div>

                <p class="lead text-muted mb-4" style="line-height: 1.8;">
                    Bugünden yarına değer katmak için var gücümüzle çalışıyoruz.
                </p>

                <div class="bg-light p-4 rounded-4 border-start border-4 border-success mb-4">
                    <h5 class="fw-bold text-success">Görevimiz Ne?</h5>
                    <p class="mb-0 text-secondary">
                        Derneğimizin kuruluş amacı olan yardımlaşma ruhunu, eğitimden sağlığa her alanda fırsat eşitliğini savunarak ve ihtiyaç sahiplerine en hızlı şekilde ulaşarak hayata geçirmektir.
                    </p>
                </div>

                <div class="row g-3">
                    <div class="col-6">
                        <div class="p-3 border rounded-4 text-center shadow-sm">
                            <i class="fa-solid fa-handshake-angle text-success fa-2x mb-2"></i>
                            <h6 class="fw-bold">Yardımlaşma</h6>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 border rounded-4 text-center shadow-sm">
                            <i class="fa-solid fa-scale-balanced text-success fa-2x mb-2"></i>
                            <h6 class="fw-bold">Adalet</h6>
                        </div>
                    </div>
                </div>

                <a asp-action="Vizyon" class="btn btn-outline-success rounded-pill px-4 mt-4 fw-bold"><i class="fa-solid fa-arrow-left me-2"></i> Vizyonumuza Dön</a>
            </div>
            <div class="col-lg-5 d-none d-lg-block order-1 order-lg-2" style="background: url('https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=2071&auto=format&fit=crop') center/cover;">
            </div>
        </div>
    </div>
</div>