@model IEnumerable<DernekSitesi.Models.Toplanti>
@{
    ViewData["Title"] = "Ana Sayfa";
}

<style>
    .hero-title {
        font-weight: 800;
        font-size: 3.8rem;
        background: linear-gradient(135deg, #ffffff 0%, #b2bec3 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        letter-spacing: -1.5px;
    }

    .glass-card {
        background: rgba(255, 255, 255, 0.5);
        backdrop-filter: blur(20px) saturate(180%);
        -webkit-backdrop-filter: blur(20px) saturate(180%);
        border: 1px solid rgba(255, 255, 255, 0.4);
        border-radius: 28px;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        box-shadow: 0 10px 40px rgba(0,0,0,0.03);
        overflow: hidden;
    }

        .glass-card:hover {
            transform: translateY(-8px) scale(1.02);
            background: rgba(255, 255, 255, 0.7);
            border: 1px solid rgba(255, 255, 255, 0.6);
            box-shadow: 0 25px 50px rgba(0,0,0,0.1);
        }

    .icon-gradient-warning {
        font-size: 3.2rem;
        background: linear-gradient(135deg, #fdcb6e 0%, #ffeaa7 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .btn-premium {
        background: linear-gradient(135deg, #ff9f43 0%, #ff6b6b 100%);
        color: white !important;
        border: none;
        padding: 14px 30px;
        border-radius: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 0.9rem;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(255, 107, 107, 0.3);
    }

        .btn-premium:hover {
            box-shadow: 0 8px 25px rgba(255, 107, 107, 0.5);
            transform: translateY(-2px);
        }

    .premium-hero {
        background: linear-gradient(135deg, rgba(11, 43, 38, 0.9) 0%, rgba(32, 58, 67, 0.95) 50%, rgba(11, 43, 38, 0.9) 100%), url('https://images.unsplash.com/photo-1517048676732-d65bc937f952?q=80&w=2070&auto=format&fit=crop') center/cover no-repeat;
    }

    .news-card {
        border: none;
        border-radius: 20px;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        transition: 0.4s ease;
    }

        .news-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 25px 50px rgba(0,0,0,0.15);
        }

    .btn-premium-green {
        background: linear-gradient(135deg, #0b2b26 0%, #00b894 100%);
        color: white !important;
        border: none;
        transition: all 0.3s ease;
    }

        .btn-premium-green:hover {
            box-shadow: 0 8px 25px rgba(0, 184, 148, 0.5);
            transform: translateY(-2px);
        }

    .object-fit-cover {
        object-fit: cover;
    }

    .bento-item {
        transition: transform 0.4s ease, box-shadow 0.4s ease;
    }

    .bento-img {
        transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .bento-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(to top, rgba(11, 43, 38, 0.95) 0%, rgba(11, 43, 38, 0.4) 50%, transparent 100%);
        opacity: 0;
        transition: opacity 0.4s ease;
    }

    .bento-item:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px rgba(0,0,0,0.1) !important;
        z-index: 10;
    }

        .bento-item:hover .bento-img {
            transform: scale(1.1);
        }

        .bento-item:hover .bento-overlay {
            opacity: 1;
        }

    /* YÖNETİM KARTLARI STİLLERİ */
    .management-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,.175) !important;
    }

        .management-card:hover h5 {
            color: #0d6efd;
        }
</style>

<div class="p-5 mb-5 text-white rounded-5 shadow-2xl premium-hero text-center d-flex align-items-center justify-content-center" style="min-height: 45vh; margin-top: -20px;">
    <div class="col-lg-10">
        <h1 class="hero-title mb-4">Geleceğimizi Birlikte İnşa Ediyoruz</h1>
        <p class="lead mb-5 text-light opacity-80">Toplum için değer üreten yenilikçi derneğimize hoş geldiniz.</p>
        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a href="#haberler" class="btn btn-premium px-5 rounded-pill">Son Haberler</a>
            <a asp-controller="Uyes" asp-action="Create" class="btn btn-outline-light px-5 rounded-pill py-3 fw-bold shadow-sm" style="text-decoration:none; border-width:2px;">Üye Ol</a>
        </div>
    </div>
</div>

@if (ViewBag.SliderGorseller != null)
{
    var gorseller = (ViewBag.SliderGorseller as IEnumerable<DernekSitesi.Models.GaleriGorsel>).ToList();
    if (gorseller != null && gorseller.Any())
    {
        <div class="row mb-5 mt-4">
            <div class="col-12 text-center mb-4">
                <h2 class="fw-bold display-6" style="color: #0b2b26;">Anılardan Kareler</h2>
                <hr class="mx-auto" style="width:70px; height:4px; background:#f39c12; border-radius: 2px;">
            </div>

            <div class="col-12">
                <div class="card border-0 shadow-lg rounded-5 p-3" style="background-color: #ffffff;">
                    <div class="row g-3">
                        <div class="col-lg-6">
                            <a asp-controller="Home" asp-action="Galeri" class="text-decoration-none d-block h-100 position-relative overflow-hidden rounded-4 bento-item">
                                <img src="@gorseller[0].ResimYolu" class="w-100 h-100 object-fit-cover bento-img" style="min-height: 420px;" alt="@gorseller[0].Baslik">
                                <div class="bento-overlay d-flex flex-column justify-content-end p-4">
                                    <h3 class="text-white fw-bold mb-2">@gorseller[0].Baslik</h3>
                                    <div>
                                        <span class="badge bg-warning text-dark px-3 py-2 rounded-pill shadow-sm">
                                            <i class="fa-solid fa-expand me-1"></i>Tüm Galeriyi Gör
                                        </span>
                                    </div>
                                </div>
                            </a>
                        </div>
                        <div class="col-lg-6">
                            <div class="row g-3 h-100">
                                @for (int i = 1; i < Math.Min(5, gorseller.Count); i++)
                                {
                                    <div class="col-6">
                                        <a asp-controller="Home" asp-action="Galeri" class="text-decoration-none d-block h-100 position-relative overflow-hidden rounded-4 bento-item">
                                            <img src="@gorseller[i].ResimYolu" class="w-100 h-100 object-fit-cover bento-img" style="min-height: 202px;" alt="@gorseller[i].Baslik">
                                            <div class="bento-overlay d-flex align-items-center justify-content-center">
                                                <i class="fa-solid fa-plus fa-3x text-white opacity-75"></i>
                                            </div>
                                        </a>
                                    </div>
                                }
                                @for (int i = gorseller.Count; i < 5; i++)
                                {
                                    <div class="col-6">
                                        <a asp-controller="Home" asp-action="Galeri" class="text-decoration-none d-block h-100 rounded-4 d-flex flex-column align-items-center justify-content-center bg-light border bento-item" style="min-height: 202px;">
                                            <div class="p-3 bg-white rounded-circle shadow-sm mb-2"><i class="fa-solid fa-camera text-muted fs-4"></i></div>
                                            <span class="text-muted fw-bold small">Daha Fazla Anı</span>
                                        </a>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
}

<div class="row g-4 mb-5">
    <div class="col-12">
        <div class="card glass-card p-5 border-0 shadow-sm" style="background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);">
            <div class="text-center mb-4">
                <div class="icon-gradient-warning mb-3"><i class="fa-regular fa-calendar-check"></i></div>
                <h3 class="fw-bold text-dark mb-0">Yaklaşan Toplantı</h3>
            </div>
            @if (Model != null && Model.Any())
            {
                var t = Model.First();
                <div class="row align-items-center bg-white rounded-5 shadow-sm border p-3 mx-auto" style="max-width: 950px;">
                    <div class="col-md-6 text-center text-md-start p-4">
                        <h3 class="fw-bold text-warning mb-4">@t.Baslik</h3>
                        <div class="d-flex align-items-center justify-content-center justify-content-md-start mb-3">
                            <div class="bg-light p-3 rounded-circle me-3 shadow-sm"><i class="fa-regular fa-clock text-primary fs-4"></i></div>
                            <div>
                                <small class="text-muted fw-bold d-block">Tarih & Saat</small>
                                <span class="text-dark fs-5 fw-bold">@t.Tarih.ToString("dd MMMM yyyy - HH:mm")</span>
                            </div>
                        </div>
                        <div class="d-flex align-items-center justify-content-center justify-content-md-start mb-4">
                            <div class="bg-light p-3 rounded-circle me-3 shadow-sm"><i class="fa-solid fa-location-dot text-danger fs-4"></i></div>
                            <div>
                                <small class="text-muted fw-bold d-block">Konum</small>
                                <span class="text-dark fs-5 fw-bold">@t.Konum</span>
                            </div>
                        </div>
                        <a href="https://www.google.com/maps/search/?api=1&query=@Uri.EscapeDataString(t.Konum)" target="_blank" class="btn btn-outline-dark rounded-pill px-4 py-2 fw-bold shadow-sm w-100">
                            <i class="fa-solid fa-map-location-dot me-2"></i>Haritada Yol Tarifi Al
                        </a>
                    </div>
                    <div class="col-md-6 p-2">
                        <div class="rounded-4 overflow-hidden shadow-sm border" style="height: 300px; position: relative; background-color:#e9ecef;">
                            <iframe width="100%" height="100%" frameborder="0" style="border:0;" src="https://maps.google.com/maps?q=@Uri.EscapeDataString(t.Konum)&t=&z=14&ie=UTF8&iwloc=&output=embed" allowfullscreen></iframe>
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="p-4 bg-light rounded-4 d-inline-block mx-auto text-muted fw-bold text-center">
                    <i class="fa-solid fa-calendar-xmark me-2 text-danger"></i>Şu an planlanmış bir toplantı yok.
                </div>
            }
        </div>
    </div>
</div>

<div id="haberler" class="row mb-5 mt-5">
    <div class="col-12 text-center mb-5">
        <h2 class="fw-bold display-6">Dernekten Haberler</h2>
        <hr class="mx-auto" style="width:70px; height:4px; background:#0b2b26; border-radius: 2px;">
    </div>
    @if (ViewBag.SonHaberler != null)
    {
        var haberler = ViewBag.SonHaberler as IEnumerable<DernekSitesi.Models.Haber>;
        foreach (var haber in haberler)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 border-0 rounded-5 shadow-lg news-card overflow-hidden position-relative" style="background-color: #ffffff;">
                    @if (!string.IsNullOrEmpty(haber.ResimYolu))
                    {
                        <img src="@haber.ResimYolu" class="card-img-top" alt="@haber.Baslik" style="height: 220px; object-fit: cover;">
                    }
                    else
                    {
                        <div class="card-img-top d-flex align-items-center justify-content-center" style="height: 220px; background: linear-gradient(135deg, #0b2b26 0%, #1a4a40 100%);">
                            <i class="fa-regular fa-image fa-3x text-white opacity-25"></i>
                        </div>
                    }
                    <div class="card-body p-4 d-flex flex-column">
                        <div class="small fw-bold mb-3 d-flex align-items-center">
                            <span class="badge rounded-pill bg-light text-success border me-2" style="padding: 6px 12px; background-color: rgba(0, 184, 148, 0.1) !important;">
                                <i class="fa-regular fa-calendar-days me-1"></i>
                                @haber.YayinTarihi.ToString("dd MMMM yyyy")
                            </span>
                        </div>
                        <h4 class="fw-bold mb-3" style="color: #0b2b26;">@haber.Baslik</h4>
                        <p class="text-muted flex-grow-1" style="line-height: 1.8; font-size: 1.05rem;">
                            @(haber.Icerik != null && haber.Icerik.Length > 100 ? haber.Icerik.Substring(0, 100) + "..." : haber.Icerik)
                        </p>
                        <a asp-controller="Habers" asp-action="Details" asp-route-id="@haber.Id" class="btn btn-premium-green rounded-pill mt-4 px-4 py-2 fw-bold text-uppercase shadow-sm w-100" style="letter-spacing: 1px;">
                            Devamını Oku <i class="fa-solid fa-arrow-right ms-2 fs-6"></i>
                        </a>
                    </div>
                </div>
            </div>
        }
    }
</div>

@if (ViewBag.YonetimKadrosu != null)
{
    var kadro = ViewBag.YonetimKadrosu as IEnumerable<DernekSitesi.Models.YonetimUyesi>;
    if (kadro != null && kadro.Any())
    {
        <section class="py-5 bg-light rounded-5 shadow-sm mb-5">
            <div class="container">
                <div class="text-center mb-5">
                    <h2 class="fw-bold display-6" style="color: #0b2b26;">Yönetim Kurulumuz</h2>
                    <hr class="mx-auto" style="width:70px; height:4px; background:#00b894; border-radius: 2px;">
                    <p class="text-muted mt-3" style="font-size: 1.1rem;">Derneğimizin geleceğine yön veren değerli üyelerimiz.</p>
                </div>
                <div class="row g-4 justify-content-center">
                    @foreach (var item in kadro)
                    {
                        <div class="col-md-6 col-lg-3">
                            <div class="card h-100 border-0 shadow-sm rounded-4 text-center p-3 management-card"
                                 style="cursor: pointer; transition: transform 0.3s;"
                                 data-bs-toggle="modal"
                                 data-bs-target="#modal-@item.Id">

                                <div class="position-relative d-inline-block mx-auto mb-3">
                                    @if (!string.IsNullOrEmpty(item.ResimYolu))
                                    {
                                        <img src="@item.ResimYolu" class="rounded-circle object-fit-cover shadow border border-3 border-white" style="width: 130px; height: 130px;" alt="@item.AdSoyad">
                                    }
                                    else
                                    {
                                        <div class="rounded-circle bg-white d-flex align-items-center justify-content-center shadow border border-3 border-white text-secondary" style="width: 130px; height: 130px; font-size: 3rem;">
                                            <i class="fa-solid fa-user-tie"></i>
                                        </div>
                                    }
                                </div>
                                <h5 class="fw-bold mb-1">@item.AdSoyad</h5>
                                <p class="small fw-bold mb-0" style="color: #00b894;">@item.Gorev</p>
                                <div class="mt-3 text-muted" style="font-size: 0.8rem;">
                                    <i class="fa-solid fa-magnifying-glass-plus me-1"></i> Detaylı Bilgi
                                </div>
                            </div>

                            <div class="modal fade" id="modal-@item.Id" tabindex="-1" aria-hidden="true">
                                <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content border-0 rounded-5 shadow-lg">
                                        <div class="modal-header border-0 pb-0"><button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button></div>
                                        <div class="modal-body p-5 text-center">
                                            @if (!string.IsNullOrEmpty(item.ResimYolu))
                                            {
                                                <img src="@item.ResimYolu" class="rounded-circle shadow mb-4 border border-4 border-light" style="width: 150px; height: 150px; object-fit: cover;">
                                            }
                                            <h3 class="fw-bold text-dark mb-1">@item.AdSoyad</h3>
                                            <span class="badge bg-primary rounded-pill px-4 py-2 mb-4" style="background-color: #0b2b26 !important;">@item.Gorev</span>
                                            <div class="bg-light p-4 rounded-4 text-start">
                                                <h6 class="fw-bold text-secondary mb-3"><i class="fa-solid fa-address-card me-2"></i>Hakkında / Özgeçmiş</h6>
                                                <p class="text-muted mb-0" style="line-height: 1.6; white-space: pre-line;">@(string.IsNullOrEmpty(item.Ozgecmis) ? "Bu yöneticiye ait özgeçmiş bilgisi henüz eklenmemiştir." : item.Ozgecmis)</p>
                                            </div>
                                            <div class="d-flex justify-content-center gap-3 mt-4">
                                                @if (!string.IsNullOrEmpty(item.TwitterLink))
                                                {
                                                    <a href="@item.TwitterLink" target="_blank" class="btn btn-outline-info rounded-circle"><i class="fa-brands fa-twitter"></i></a>
                                                }
                                                @if (!string.IsNullOrEmpty(item.LinkedInLink))
                                                {
                                                    <a href="@item.LinkedInLink" target="_blank" class="btn btn-outline-primary rounded-circle"><i class="fa-brands fa-linkedin-in"></i></a>
                                                }
                                                @if (!string.IsNullOrEmpty(item.InstagramLink))
                                                {
                                                    <a href="@item.InstagramLink" target="_blank" class="btn btn-outline-danger rounded-circle"><i class="fa-brands fa-instagram"></i></a>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </section>
    }
}

<div class="row mb-5 mt-5">
    <div class="col-lg-10 mx-auto">
        <div class="card border-0 shadow-lg rounded-5 overflow-hidden">
            <div class="row g-0">
                <div class="col-md-5 text-white p-5 d-flex flex-column justify-content-center" style="background: linear-gradient(135deg, #0b2b26 0%, #1a4a40 100%);">
                    <h3 class="fw-bold mb-4">Bizimle İletişime Geçin</h3>
                    <p class="opacity-75 mb-5">Projelerimiz, üyelik süreci veya aklınıza takılan her türlü soru için bize yazabilirsiniz.</p>
                    <div class="d-flex align-items-center mb-4"><div class="bg-white bg-opacity-10 p-3 rounded-circle me-3"><i class="fa-solid fa-location-dot"></i></div><div><h6 class="mb-0 fw-bold">Adres</h6><small class="opacity-75">Merkez Mahallesi, Dernek Sokak No:1</small></div></div>
                    <div class="d-flex align-items-center mb-4"><div class="bg-white bg-opacity-10 p-3 rounded-circle me-3"><i class="fa-solid fa-envelope"></i></div><div><h6 class="mb-0 fw-bold">E-Posta</h6><small class="opacity-75">info@derneksitesi.com</small></div></div>
                </div>
                <div class="col-md-7 p-5 bg-white">
                    @if (TempData["MesajDurum"]?.ToString() == "Basarili")
                    {
                        <div class="alert alert-success rounded-4 border-0 shadow-sm mb-4"><i class="fa-solid fa-circle-check me-2"></i> Mesajınız başarıyla gönderildi!</div>
                    }
                    else if (TempData["MesajDurum"]?.ToString() == "Hata")
                    {
                        <div class="alert alert-danger rounded-4 border-0 shadow-sm mb-4"><i class="fa-solid fa-circle-exclamation me-2"></i> Lütfen tüm alanları eksiksiz doldurun.</div>
                    }
                    <form asp-controller="Home" asp-action="MesajGonder" method="post">
                        <div class="row g-3">
                            <div class="col-md-6"><label class="form-label fw-bold small text-muted">Adınız Soyadınız</label><input type="text" name="AdSoyad" class="form-control form-control-lg bg-light border-0" required></div>
                            <div class="col-md-6"><label class="form-label fw-bold small text-muted">E-Posta Adresiniz</label><input type="email" name="Email" class="form-control form-control-lg bg-light border-0" required></div>
                            <div class="col-12"><label class="form-label fw-bold small text-muted">Konu</label><input type="text" name="Konu" class="form-control form-control-lg bg-light border-0" required></div>
                            <div class="col-12"><label class="form-label fw-bold small text-muted">Mesajınız</label><textarea name="Icerik" class="form-control form-control-lg bg-light border-0" rows="4" required></textarea></div>
                            <div class="col-12 mt-4"><button type="submit" class="btn btn-success btn-lg w-100 rounded-pill fw-bold shadow-sm" style="background-color: #0b2b26; border:none;"><i class="fa-regular fa-paper-plane me-2"></i>Mesajı Gönder</button></div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mb-5 mt-5">
    <div class="col-12">
        <div class="card border-0 rounded-5 shadow-sm position-relative overflow-hidden mx-auto" style="background: linear-gradient(135deg, #0b2b26 0%, #00b894 100%); color:white; max-width: 800px;">
            <div class="card-body p-5 text-center">
                <i class="fa-solid fa-users-viewfinder fa-3x mb-3 opacity-50"></i>
                <h1 class="display-2 fw-bold mb-0">@ViewBag.UyeSayisi</h1>
                <h4 class="fw-light opacity-75 mt-2">Aktif Üye Sayımız</h4>
                <p class="mt-3 opacity-50 small mb-0">Derneğimizin gücüne güç katan tüm üyelerimize teşekkür ederiz.</p>
            </div>
            <div style="position: absolute; right: -20px; bottom: -40px; font-size: 12rem; opacity: 0.05; transform: rotate(-15deg);">
                <i class="fa-solid fa-users"></i>
            </div>
        </div>
    </div>
</div>